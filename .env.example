# Gemini API key (required for CV parsing, matching, skill-gap, cover letter LLM calls)
# Create a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-api-key-here

# Gemini model for all graph LLM nodes (default: gemini-2.5-flash)
MODEL_NAME=gemini-2.5-flash

# JobSpy transport: "sse" (default, HTTP on :9423) or "stdio" (spawns MCP subprocess)
# JOBSPY_TRANSPORT=sse
# JOBSPY_SSE_URL=http://localhost:9423

# Hide Streamlit header/toolbar/footer for screen recordings (set to 1 before starting)
# UI_HIDE_STREAMLIT_CHROME=1
